---
import 'plyr/dist/plyr.css';

interface Props {
	id: string;
	title?: string;
}
const { id, title = 'YouTube video' } = Astro.props;
---

<div class="plyr-wrapper">
	<div
		data-plyr-provider="youtube"
		data-plyr-embed-id={id}
		aria-label={title}
	></div>
</div>

<style>
	.plyr-wrapper :global(.plyr) {
		--plyr-color-main: #4a3f8f;
	}

	.plyr-wrapper :global(.plyr__control--overlaid) {
		display: none;
	}
</style>

<script>
	import Plyr from 'plyr';

	document.querySelectorAll<HTMLElement>('[data-plyr-provider="youtube"]').forEach((el) => {
		new Plyr(el, {
			youtube: {
				rel: 0,
				iv_load_policy: 3,
				modestbranding: 1,
			},
		});
	});
</script>
