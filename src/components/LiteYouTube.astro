---
import 'lite-youtube-embed/src/lite-yt-embed.css';

interface Props {
	id: string;
	title?: string;
	poster?: string;
	params?: string;
}
const {
	id,
	title = 'YouTube video',
	poster,
	params = 'rel=0&playsinline=1',
} = Astro.props;
---

<lite-youtube
	videoid={id}
	playlabel={`Play: ${title}`}
	params={params}
	style={poster ? `background-image: url('${poster}');` : ''}
></lite-youtube>

<style>
	lite-youtube {
		width: 100%;
		max-width: 100%;
		border-radius: 2px;
	}

	lite-youtube :global(.lyt-playbtn) {
		transition: none !important;
	}

	lite-youtube:hover > :global(.lyt-playbtn),
	lite-youtube :global(.lyt-playbtn:focus) {
		filter: grayscale(0%) hue-rotate(249deg) saturate(0.8) brightness(1.1) !important;
	}
</style>

<script>
	import 'lite-youtube-embed/src/lite-yt-embed.js';

	const isTouchDevice = navigator.maxTouchPoints > 0 || 'ontouchstart' in window;

	if (isTouchDevice) {
		document.querySelectorAll('lite-youtube').forEach((el) => {
			el.addEventListener('click', (e) => {
				e.preventDefault();
				e.stopImmediatePropagation();
				const id = el.getAttribute('videoid');
				window.open(`https://www.youtube.com/watch?v=${id}`, '_blank');
			}, true);
		});
	}
</script>
